import { Button, GridBox, LineEdit } from "std-widgets.slint";

component AutoclickUI inherits Rectangle {
    callback start(bool);

    GridLayout {
        Button {
            col: 0;
            text: "start";

            clicked => {
                root.start(true);
            }
        }

        Button {
            col: 1;
            text: "stop";

            clicked => {
                root.start(false);
            }
        }
    }
}

export component MainWindow inherits Window {
    // icon: @image-url("icons/design.svg");
    title: @tr("AutoClick");

    callback start(bool);

    width: 326px;
    height: 326px;
    
    AutoclickUI {
        start(bool) => { root.start(bool) }
    }
}
